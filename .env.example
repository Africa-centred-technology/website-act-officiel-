# ─── Shopify Storefront API (catalogue des formations) ───
SHOPIFY_STORE_DOMAIN=act-formation.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=

# ─── Shopify Admin API (inscriptions / Draft Orders) ───
# Token privé : "shpat_..." ou secret OAuth
SHOPIFY_ADMIN_ACCESS_TOKEN=
SHOPIFY_CLIENT_ID=

# ─── Resend (envoi d'emails depuis le formulaire de contact) ───
# https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
